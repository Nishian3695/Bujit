<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Income stream picker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:alpha="0.5"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:text="INCOME STREAM"
            android:textColor="?attr/colorOnSurface"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/proj_stream_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Stream">

            <AutoCompleteTextView
                android:id="@+id/proj_stream_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/colorControlHighlight" />

        <!-- Projection period -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:alpha="0.5"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:text="PROJECTION PERIOD"
            android:textColor="?attr/colorOnSurface"
            android:textSize="11sp" />

        <!-- "Use stream's period" radio -->
        <RadioGroup
            android:id="@+id/proj_period_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/proj_period_stream"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="Use stream's period"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/proj_period_custom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:text="Custom period"
                android:textSize="14sp" />

        </RadioGroup>

        <!-- Custom period inputs (shown when "Custom period" is selected) -->
        <LinearLayout
            android:id="@+id/proj_custom_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/proj_custom_mag_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/proj_custom_mag_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:inputType="number" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/proj_custom_unit_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Unit">

                <AutoCompleteTextView
                    android:id="@+id/proj_custom_unit_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:inputType="none" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Hint text about non-persistence -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:alpha="0.45"
            android:fontFamily="sans-serif"
            android:text="Custom settings apply to this session only and reset on relaunch."
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp" />

        <!-- Bottom padding for dialog buttons -->
        <View
            android:layout_width="match_parent"
            android:layout_height="8dp" />

    </LinearLayout>

</ScrollView>
