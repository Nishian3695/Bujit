<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <!-- ── APPEARANCE section ── -->
        <TextView
            android:id="@+id/section_header_appearance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="APPEARANCE"
            android:textColor="?attr/colorPrimary"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- App Theme row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="App Theme"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/theme_toggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <Button
                            android:id="@+id/btn_system"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="System"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btn_light"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Light"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btn_dark"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Dark"
                            android:textSize="13sp" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorControlHighlight" />

                <!-- Accent Color row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="Accent Color"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <!-- Blue -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/swatch_blue"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_margin="4dp"
                            app:cardBackgroundColor="@color/primary_blue"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <TextView
                                android:id="@+id/check_blue"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Purple -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/swatch_purple"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_margin="4dp"
                            app:cardBackgroundColor="@color/accent_purple"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <TextView
                                android:id="@+id/check_purple"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Green -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/swatch_green"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_margin="4dp"
                            app:cardBackgroundColor="@color/accent_green"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <TextView
                                android:id="@+id/check_green"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Orange -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/swatch_orange"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_margin="4dp"
                            app:cardBackgroundColor="@color/accent_orange"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <TextView
                                android:id="@+id/check_orange"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Teal -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/swatch_teal"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_margin="4dp"
                            app:cardBackgroundColor="@color/accent_teal"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <TextView
                                android:id="@+id/check_teal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Rose -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/swatch_rose"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_margin="4dp"
                            app:cardBackgroundColor="@color/accent_rose"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <TextView
                                android:id="@+id/check_rose"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Custom hex color row -->
                    <LinearLayout
                        android:id="@+id/row_custom_color"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/swatch_custom"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_margin="5dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="3dp">
                            <TextView
                                android:id="@+id/check_custom"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Custom color…"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── INTEGRATIONS section ── -->
        <TextView
            android:id="@+id/section_header_integrations"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="INTEGRATIONS"
            android:textColor="?attr/colorPrimary"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Connected state row (shown when signed in) -->
                <LinearLayout
                    android:id="@+id/row_google_connected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google Calendar Sync"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_google_account"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:alpha="0.6"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_google_disconnect"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disconnect"
                        android:textColor="@color/accent_rose"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Disconnected state row (shown when not signed in) -->
                <LinearLayout
                    android:id="@+id/row_google_connect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google Calendar Sync"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:alpha="0.6"
                            android:text="Add expenses and paychecks to Google Calendar"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="›"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="20sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── SUPPORT section ── -->
        <TextView
            android:id="@+id/section_header_support"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="SUPPORT"
            android:textColor="?attr/colorPrimary"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/row_help_suggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Help / Suggestions"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:alpha="0.6"
                            android:text="Send feedback or report an issue"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="›"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="20sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorControlHighlight" />

                <LinearLayout
                    android:id="@+id/row_tutorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tutorial"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:alpha="0.6"
                            android:text="Replay the getting started walkthrough"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="›"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="20sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── DATA section ── -->
        <TextView
            android:id="@+id/section_header_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="DATA"
            android:textColor="?attr/colorPrimary"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:id="@+id/row_clear_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear All Data"
                    android:textColor="@color/accent_rose"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:alpha="0.6"
                    android:text="Permanently removes all expenses, balance, and linked accounts"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="13sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── LEGAL section ── -->
        <TextView
            android:id="@+id/section_header_legal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:text="LEGAL"
            android:textColor="?attr/colorPrimary"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Privacy Policy row -->
                <LinearLayout
                    android:id="@+id/row_privacy_policy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Privacy Policy"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="›"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="20sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorControlHighlight" />

                <!-- Teller Privacy Policy row -->
                <LinearLayout
                    android:id="@+id/row_teller_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teller Legal and Privacy Policy"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:alpha="0.6"
                            android:text="Third-party banking data provider"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="›"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="20sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorControlHighlight" />

                <!-- Disclaimer row -->
                <LinearLayout
                    android:id="@+id/row_disclaimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Disclaimer"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="›"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="20sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
