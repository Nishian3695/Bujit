<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ExpenseActivity.ExpenseActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_constraint_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:animateLayoutChanges="false">

        <!-- ── Check period navigation bar ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/check_bar_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/prev_check_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="◀"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/current_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="This Check"
                        android:textColor="@color/white"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/check_bar_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:alpha="0.75"
                        android:textSize="11sp"
                        android:visibility="gone" />

                </LinearLayout>

                <Button
                    android:id="@+id/next_check_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="▶"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Balance summary card ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/balance_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/check_bar_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Current Balance -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingTop="16dp"
                        android:paddingBottom="14dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.5"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06"
                            android:text="CURRENT BALANCE"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/current_balance_TV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="?attr/selectableItemBackground"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:minWidth="3dp"
                            android:text="$0.00"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:background="?attr/colorControlHighlight" />

                    <!-- After-Check Balance -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingTop="16dp"
                        android:paddingBottom="14dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.5"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06"
                            android:text="AFTER THIS CHECK"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/final_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:minWidth="3dp"
                            android:text="$0.00"
                            android:textSize="24sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Sync label -->
                <TextView
                    android:id="@+id/sync_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:alpha="0.5"
                    android:gravity="center"
                    android:paddingBottom="8dp"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="11sp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Expense table column headers ── -->
        <LinearLayout
            android:id="@+id/expense_table_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/balance_card">

            <TextView
                android:id="@+id/expense_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:alpha="0.45"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="EXPENSE"
                android:textColor="?attr/colorOnSurface"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/date_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.5"
                android:alpha="0.45"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="DUE DATE"
                android:textColor="?attr/colorOnSurface"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/rate_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:alpha="0.45"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="RATE"
                android:textColor="?attr/colorOnSurface"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/cost_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:alpha="0.45"
                android:fontFamily="sans-serif-medium"
                android:gravity="end"
                android:letterSpacing="0.08"
                android:text="AMOUNT"
                android:textColor="?attr/colorOnSurface"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/status_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="STATUS"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Header / list divider -->
        <View
            android:id="@+id/table_header_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/colorControlHighlight"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/expense_table_header" />

        <!-- ── Expense list ── -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/table_header_divider">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/expense_table"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="88dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- ── Speed dial scrim ── -->
        <View
            android:id="@+id/speed_dial_scrim"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#80000000"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── Speed dial: Recurring Expense mini FAB (centered over main FAB) ── -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/speed_dial_recurring_fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="Add recurring expense"
            android:src="@drawable/sharp_add"
            android:visibility="gone"
            app:fabSize="mini"
            app:layout_constraintBottom_toTopOf="@id/add_button"
            app:layout_constraintEnd_toEndOf="@id/add_button"
            app:layout_constraintStart_toStartOf="@id/add_button" />

        <!-- ── Speed dial: Recurring Expense label ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/speed_dial_recurring_label_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="6dp"
            app:cardElevation="4dp"
            app:layout_constraintBottom_toBottomOf="@id/speed_dial_recurring_fab"
            app:layout_constraintEnd_toStartOf="@id/speed_dial_recurring_fab"
            app:layout_constraintTop_toTopOf="@id/speed_dial_recurring_fab">

            <TextView
                android:id="@+id/speed_dial_recurring_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="Recurring Expense"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Speed dial: Single Event mini FAB (centered over main FAB) ── -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/speed_dial_single_event_fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:contentDescription="Add single event"
            android:src="@drawable/sharp_add"
            android:visibility="gone"
            app:fabSize="mini"
            app:layout_constraintBottom_toTopOf="@id/speed_dial_recurring_fab"
            app:layout_constraintEnd_toEndOf="@id/add_button"
            app:layout_constraintStart_toStartOf="@id/add_button" />

        <!-- ── Speed dial: Single Event label ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/speed_dial_single_event_label_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="6dp"
            app:cardElevation="4dp"
            app:layout_constraintBottom_toBottomOf="@id/speed_dial_single_event_fab"
            app:layout_constraintEnd_toStartOf="@id/speed_dial_single_event_fab"
            app:layout_constraintTop_toTopOf="@id/speed_dial_single_event_fab">

            <TextView
                android:id="@+id/speed_dial_single_event_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="Single Event"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ── FAB ── -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/add_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:contentDescription="ADD"
            android:src="@drawable/sharp_add"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/main_navigation_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/navigation_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
