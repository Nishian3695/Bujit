<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <!-- Expense name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/add_expense_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Expense name">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/expense_name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:inputType="textCapWords" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/add_expense_cost"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Amount"
            app:prefixText="$ ">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/expense_cost_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:inputType="numberDecimal" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- From Connected Account -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_from_connected"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="From Connected Account"
            android:textAllCaps="false"
            android:textSize="14sp" />

        <!-- Shown after an account is picked -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/linked_account_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/linked_banner_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:fontFamily="sans-serif-medium"
                    android:text="Linked: "
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/linked_account_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_unlink_account"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="Unlink"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Frequency section label -->
        <TextView
            android:id="@+id/add_expense_frequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp"
            android:alpha="0.5"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:text="REPEATS EVERY"
            android:textColor="?attr/colorOnSurface"
            android:textSize="11sp" />

        <!-- Frequency: number + unit row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/expense_frequency_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:hint="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/expense_frequency_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:inputType="number" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Unit">

                <AutoCompleteTextView
                    android:id="@+id/expense_frequency_magnitude_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:inputType="none" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Start date -->
        <TextView
            android:id="@+id/add_expense_start_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp"
            android:alpha="0.5"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:text="STARTING DATE"
            android:textColor="?attr/colorOnSurface"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/expense_start_date_input_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text=""
            android:textAllCaps="false"
            android:textSize="14sp" />

        <!-- Google Calendar notification settings -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="?attr/colorControlHighlight" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:alpha="0.5"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:text="GOOGLE CALENDAR"
            android:textColor="?attr/colorOnSurface"
            android:textSize="11sp" />

        <!-- Shown when calendar sync IS enabled -->
        <LinearLayout
            android:id="@+id/row_calendar_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show in Google Calendar"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:alpha="0.6"
                    android:text="Adds a due date so this task appears in your calendar"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_calendar_notifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Shown when calendar sync is NOT enabled -->
        <TextView
            android:id="@+id/tv_no_calendar_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.55"
            android:text="Enable Google Calendar Sync in Settings to show this expense in Google Calendar"
            android:textColor="?attr/colorOnSurface"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
